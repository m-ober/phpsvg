{
    "name": "mober/phpsvg",
    "description": "Edit and create SVG Documents using OO PHP",
    "keywords": ["SVG", "PHP"],
    "homepage": "https://github.com/m-ober/phpsvg",
    "license": "GPL-3.0",
    "authors": [
        {"name": "Dampfklon", "email": "me@dampfklon.de" },
        {"name": "Micha Ober", "email": "packages@ober-mail.de" },
        {"name": "Eduardo Bonfandini", "email": "trialforce@gmail.com" }
    ],
    "require": {
        "php": "8.0 - 8.3",
        "ext-SimpleXML": "*",
        "ext-fileinfo": "*",
        "ext-dom": "*"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.5 | ^4.0",
        "vimeo/psalm": "^5.15"
    },
    "suggest": {
        "ext-imagick": "Export images using Imagick",
        "ext-zlib": "Read/write compressed files"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {"mober\\phpsvg\\": "src/"}
    },
    "scripts": {
        "phpcs": "vendor/bin/phpcs",
        "psalm": "vendor/bin/psalm --find-unused-psalm-suppress --no-cache"
    }
}
